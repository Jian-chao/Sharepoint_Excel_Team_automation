# ── Virtual environment ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python bytecode & caches ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Distribution / packaging ──────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Test & coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.coveragerc

# ── Generated / output files ──────────────────────────────────
excel_llm_prompt.txt        # auto-generated by main.py --llm-prompt
local_sharepoint/           # local SharePoint simulation folder

# ── Credentials & secrets (NEVER commit these) ───────────────
.env
*.env
secrets.py
credentials.py

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── macOS (if collaborators use Mac) ─────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter (if used for analysis) ───────────────────────────
.ipynb_checkpoints/
*.ipynb
